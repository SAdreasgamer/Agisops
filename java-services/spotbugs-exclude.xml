<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude auto-generated Protobuf code -->
    <Match>
        <Package name="~com\.aegisops\.proto\..*"/>
    </Match>

    <!-- Exclude internal representation exposure warnings triggered by Spring dependency injection -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
